\begin{solution}
    \begin{parts}
        \part Hay que recordar que cuando hay cargas que se mueven, se genera corriente. Esto viene dado por la siguiente ecuación:
        \begin{align}
            \bvec{J} = \rho \cdot \vec{v}
        \end{align}
        Donde $\rho = \rho_0$ es conocido, por ende, nos falta encontrar la velocidad. Para esto, tal como indica el hint, usamos conservación de la energía:
        \begin{align}
            K = U
        \end{align}
        Donde $K$ es la energía cinética y $U$ es la energía potencial eléctrica. Recordemos que la energía potencial eléctrica viene dada por $U = qV$. Como son los electrones los que generan corriente, usamos que la carga $q = e$. Así, planteamos la conservación de la energía:
        \begin{align}
            \frac{1}{2}mv^2 &= eV(z) \\
            \Rightarrow v &= \sqrt{\frac{2eV(z)}{m}}
        \end{align}
        Por ende, el vector densidad de corriente viene dado por:
        \begin{align}
            \bvec{J} &= \rho_0 \sqrt{\frac{2eV(z)}{m}} \hat{z}
        \end{align}
        Y la corriente viene dada por:
        \begin{align}
            I &= \iint_{S} \bvec{J} \dif{\vec{s}} \\
            I &= \int_{0}^{2\pi} \int_{0}^{R} \rho_0 \sqrt{\frac{2eV(z)}{m}} r\dif{r}\dif{\theta} \\
            I &= \frac{2 \pi \rho_0 R^2}{2} \sqrt{\frac{2eV(z)}{m}} \\
            I &= \pi \rho_0 R^2 \sqrt{\frac{2eV(z)}{m}}
        \end{align}

        \part Recordando que la ecuación de Poisson viene dada por:
        \begin{align}
            \nabla^2 V(z) &= -\frac{\rho}{\epsilon_0}
        \end{align}
        Como el potencial tiene dependencia únicamente según $z$, la EDO a resolver es:
        \begin{align}
            \frac{\partial^2V(z)}{\partial z^2} &= \frac{k}{\epsilon_0} V^{-1/2}\\
            \frac{\dif{V'}}{\dif{z}} &= \frac{k}{\epsilon_0} V^{-1/2}
        \end{align}
        Por regla de la cadena, se tiene que:
        \begin{align}
            \frac{\dif{V'}}{\dif{z}} &= \frac{\dif{V'}}{\dif{V}}\cdot \frac{\dif{V}}{\dif{z}} = \frac{\dif{V'}}{\dif{V}} \cdot V'
        \end{align}
        Reemplazando lo anterior en la EDO se tiene:
        \begin{align}
            \frac{\dif{V'}}{\dif{V}} \cdot V' &= \frac{k}{\epsilon_0} V^{-1/2} \\
            V' \dif{V'} &= \frac{k}{\epsilon_0} V^{-1/2} \dif{V} \\
            \int V' \dif{V'} &= \frac{k}{\epsilon_0} \int V^{-1/2} \dif{V} \\
            \frac{(V')^2}{2} &= \frac{k}{\epsilon_0} \frac{V^{1/2}}{1/2} + C, C \in \mathbb{R} \\
            \Rightarrow V' &= \sqrt{\frac{4k}{\epsilon_0} V^{1/2}} + C_1, C_1 = \sqrt{C} \in \mathbb{R}
        \end{align}
        Antes de seguir, hay una condición de borde útil. Recordemos que en $z=0$, las cargas parten desde el reposo, por ende, $\bvec{E}(z=0) = 0 \Rightarrow -V'(z=0) = V(z=0) = 0$. Por ende:
        \begin{align}
            -V'(z=0) &= \sqrt{\frac{4k}{\epsilon_0} V(z=0)^{1/2}} + C_1 \\
            0 &= 0 + C_1 \Rightarrow C_1 = 0
        \end{align}
        Ahora debemos resolver la EDO para encontrar $V(z)$: 
        \begin{align}
            \frac{\dif{V}}{\dif{z}} &= \sqrt{\frac{4k}{\epsilon_0} V^{1/2}}\\
            \frac{\dif{V}}{\dif{z}} &= 2 \sqrt{\frac{k}{\epsilon_0}} V^{1/4} \\
            \frac{\dif{V}}{V^{1/4}} &= 2 \sqrt{\frac{k}{\epsilon_0}} \dif{z} \\
            \int \frac{\dif{V}}{V^{1/4}} &= 2 \int \sqrt{\frac{k}{\epsilon_0}} \dif{z} \\
            \frac{V^{3/4}}{3/4} &= 2\sqrt{\frac{k}{\epsilon_0}} z + B, B \in \mathbb{R} \\
            \frac{4}{3}V^{3/4} &= 2 \sqrt{\frac{k}{\epsilon_0}} z + B \\
            V^{3/4} &= \frac{3}{2} \sqrt{\frac{k}{\epsilon_0}} z + A \\
            V(z) &= \left( \frac{3}{2} \sqrt{\frac{k}{\epsilon_0}} \right)^{4/3} \cdot z^{4/3} + A, A = B^{4/3} \in \mathbb{R}
        \end{align}
        Para despejar la constante, usamos la primera condición de borde:
        \begin{align}
            V(z=0) &= 0 \\
            \Rightarrow A = 0
        \end{align}
        Por ende, el potencial es:
        \begin{align}
            V(z) &= \left( \frac{3}{2} \sqrt{\frac{k}{\epsilon_0}} \right)^{4/3} \cdot z^{4/3}
        \end{align}
\part Para encontrar el campo, simplemente aplicamos el gradiente:
\begin{align}
    \bvec{E} &= -\nabla V \\
    \bvec{E} &= -\frac{\text{d}}{\dif{z}} \left( \left( \frac{3}{2} \sqrt{\frac{k}{\epsilon_0}} \right)^{4/3} \cdot z^{4/3} \right) \hat{z} \\
    \bvec{E} &= -\frac{4}{3} \left( \frac{3}{2} \sqrt{\frac{k}{\epsilon_0}} \right)^{4/3} \cdot z^{1/3} \hat{z}
\end{align}

        
    \end{parts}
\end{solution}

