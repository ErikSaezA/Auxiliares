\question A partir de las ecuaciones de Maxwell-Heaviside, derive la ecuación de continuidad de carga en el vacío:
\begin{align*}
    \frac{\partial \rho}{\partial t} &= - \nabla \cdot \bvec{J}
\end{align*}
\begin{solution}
    Partiendo de la ley de Ampère-Maxwell y aplicando divergencia a ambos lados:
    \begin{align}
        \nabla \times \bvec{B} &= \mu_0 \bvec{J} + \mu_0 \epsilon_0 \frac{\partial \bvec{E}}{\partial t} \\
        \nabla \cdot \left( \nabla \times \bvec{B} \right) &= \nabla \cdot \left( \mu_0 \bvec{J} + \mu_0 \epsilon_0 \frac{\partial \bvec{E}}{\partial t} \right)
    \end{align}
    Por identidad vectorial se tiene que:
    \begin{align}
        \nabla \cdot (\nabla \times \bvec{B}) = 0
    \end{align}
    Así, volviendo a lo anterior:
    \begin{align}
        \nabla \cdot \left( \mu_0 \bvec{J} + \mu_0 \epsilon_0 \frac{\partial \bvec{E}}{\partial t} \right) &= 0 \\
        \mu_0 \left(\nabla \cdot \bvec{J} \right)+ \mu_0 \epsilon_0 \frac{\partial}{\partial t} \left( \nabla \cdot\bvec{E} \right) &= 0
    \end{align}
    Por ley de Gauss, sabemos que $\nabla \cdot \bvec{E} = \rho / \epsilon_0$. Así, se obtiene:
    \begin{align}
        \mu_0 \left(\nabla \cdot \bvec{J} \right)+ \mu_0 \epsilon_0 \frac{\partial}{\partial t} \left(\frac{\rho}{\epsilon_0} \right) &= 0 \\
        \nabla \cdot \bvec{J}+ \frac{\partial \rho}{\partial t} &= 0 \\
        \frac{\partial \rho}{\partial t} &= -\nabla \cdot \bvec{J}
    \end{align}
    Y se obtiene lo pedido.
\end{solution}
