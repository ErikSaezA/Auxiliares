  \begin{solution}
    \begin{parts}
      \part Partiendo de la ley de Faraday para medios lineales:
      \begin{align}
        \nabla \times \bvec{E}                                        & = - \mu \frac{\partial \bvec{H}}{\partial t}                             \\
        \nabla \times \left(\nabla \times \bvec{E}  \right)           & = \nabla \times \left( -\mu \frac{\partial \bvec{H}}{\partial t} \right) \\
        \nabla \times \left(\nabla \times \bvec{E}  \right)           & = -\mu \frac{\partial}{\partial t}\left(\nabla \times \bvec{H}\right)    \\
        \nabla \left(\nabla \cdot \bvec{E} \right) - \nabla^2\bvec{E} & = -\mu \frac{\partial}{\partial t} \left( \nabla \times \bvec{H} \right)
      \end{align}
      Recordando que el material no está cargado ($\uprho_f = 0$), por ley de Gauss se tiene:
      \begin{align}
        \nabla \cdot \bvec{E} = 0 \Rightarrow \nabla^2\bvec{E} & = \mu \frac{\partial}{\partial t} \left( \nabla \times \bvec{H} \right)
      \end{align}
      Usando la ley de Ampère-Maxwell para medios lineales y reemplazando en lo anterior se obtiene:
      \begin{align}
        \nabla^2\bvec{E} & = \mu \frac{\partial}{\partial t} \left( \sigma \bvec{E} + \epsilon \frac{\partial \bvec{E}}{\partial t} \right) \\
        \nabla^2\bvec{E} & = \mu\sigma \frac{\partial \bvec{E}}{\partial t} + \mu\epsilon \frac{\partial^2 \bvec{E}}{\partial t^2}          \\
        \nabla^2\bvec{E} & - \mu\epsilon \frac{\partial^2 \bvec{E}}{\partial t^2} = \mu\sigma \frac{\partial \bvec{E}}{\partial t}
      \end{align}
      Finalmente, recordando que $\epsilon = \epsilon_0(1 + \chi_e)$, $\mu = \mu_0(1 + \chi_m)$ se tiene:
      \begin{align}
        \nabla^2\bvec{E} - \mu_0(1 + \chi_m) \cdot \epsilon_0(1+\chi_e) \frac{\partial^2 \bvec{E}}{\partial t^2}                          & = \sigma\mu_0(1 + \chi_m) \frac{\partial \bvec{E}}{\partial t}   \\
        \nabla^2\bvec{E} - \mu_0 \epsilon_0 \left( 1 + \chi_m + \chi_e + \chi_e \chi_m \right) \frac{\partial ^2 \bvec{E}}{\partial t ^2} & = \sigma \mu_0 (1 + \chi_e) \frac{\partial \bvec{E}}{\partial t}
      \end{align}
      Que es lo pedido.

      \part Primero hay que calcular $\mu_r$ y $\epsilon_r$:
      \begin{align}
        \epsilon_r = (1 + \chi_e) = 1+3.5 = 4.5 &  & \mu_r = (1 + \chi_m) = 1+ 0.02 = 1.02
      \end{align}

      Para el modo TE$_{10}$:
      \begin{align}
        \nu_{cutoff, 10} & = \frac{u}{2 \pi} \sqrt{\left(\frac{ \pi}{a}\right)^2} = \frac{u_0}{2 \pi \sqrt{\mu_r \epsilon_r}} \sqrt{\left(\frac{ \pi}{a}\right)^2} \approx \qty{22.6}{\giga \hertz}
      \end{align}
      Para el modo TE$_{11}$:
      \begin{align}
        \nu_{cutoff, 11} & = \frac{u}{2 \pi} \sqrt{\left(\frac{ \pi}{a}\right)^2 + \left( \frac{\pi}{b} \right)^2} = \frac{u_0}{2 \pi \sqrt{\mu_r \epsilon_r}} \sqrt{\left(\frac{ \pi}{a}\right)^2 + \left( \frac{\pi}{b} \right)^2} \approx \qty{50.5}{\giga \hertz}
      \end{align}

      \part Para facilitar los cálculos posteriores, se obtiene $F_{1,1}$:
      \begin{align}
        F_{1,1} & = \sqrt{1-\left( \frac{\nu_{\text{cutoff},11}}{\nu} \right)^2} = \sqrt{1-\left( \frac{\qty{50.5}{\giga \hertz}}{\qty{79}{\giga \hertz}} \right)^2} = \num{0.769}
      \end{align}
      Ahora se pide calcular lo siguiente:
      \begin{align}
        \eta_{TE,11}     & = \frac{\eta}{F_{1,1}} = \frac{\sqrt{\frac{\mu}{\epsilon}}}{F_{1,1}} = \frac{\sqrt{\frac{\mu_r \mu_0}{\epsilon_r \epsilon_0}}}{F_{1,1}} = \qty{233.181}{\ohm} \\
        \beta_{11}       & = \beta F_{1,1} = \omega \sqrt{\mu \epsilon} F_{1,1} = \frac{2 \pi \nu \sqrt{\mu_r \epsilon_r}}{u_0}F_{1,1} = \qty{2725.95}{\text{rad/m}}                     \\
        \lambda_{11}     & = \frac{2\pi}{\beta_{11}} = \qty{0.0023}{\meter} = \qty{2.3}{\mm}                                                                                             \\
        u_{\text{ph},11} & = \frac{\omega}{\beta_{11}} = \frac{2 \pi \nu}{\beta_{11}} = \qty{1.82e8}{\text{m/s}}
      \end{align}
      Si calculamos la velocidad en el medio:
      \begin{align}
        u & = \frac{u_0}{\sqrt{\mu_r \epsilon_r}} = \qty{1.4e8}{\text{m/s}}
      \end{align}
      Es decir, $u_{\text{ph},11} > u$ que efectivamente era de esperar. También se espera que $u_{\text{g},11} < u$.
    \end{parts}
  \end{solution}

  \question Un horno de inducción es un tipo de horno eléctrico que permite fundir metales sin contacto directo.
  Estos funcionan haciendo circular una corriente alterna por bobinas magnéticas externas, las cuales generan un campo
  magnético variable y, por lo tanto, una corriente que calienta el metal mediante el efecto Joule.
  Para analizar este mecanismo, consideraremos un modelo simplificado.

  Suponga que la bobina del horno se modela como un solenoide de largo $l$ y radio $a$, mientras que la carga metálica se representa mediante una espira circular de alambre
  de radio $a/2$ y resistencia $R$, colocada de manera coaxial al interior del solenoide. El solenoide es alimentado por una corriente alterna,
  de manera que el campo magnético en su interior es sinusoidal:
  $\bvec{B} = B_0 \cos(\omega t) \, \uvec{z}$. El objetivo de este ejercicio es determinar la corriente inducida en la espira en función del tiempo
  y calcular el flujo de energía electromagnética a través de la superficie lateral del solenoide.
  Para ello, siga los siguientes pasos:

  \begin{parts}
    \part[2] Obtenga el flujo magnético $\Phi_B$ a través de la espira.
    \part[2] Calcule la fuerza electromotriz (\textit{electromotive force}; emf) inducida en la espira y, con ello, la corriente inducida $I = \frac{\text{emf}}{R}$. \\
    \textit{Hint:} Recuerde que la {fem} corresponde a  $\text{emf} = \oint \bvec{E} \cdot \dif{\mathbf{l}}$. Además, la ley de Faraday-Lenz podría serle de gran utilidad.
    \part[3] Encuentre el campo eléctrico inducido \textbf{al interior del solenoide} debido a la presencia del campo magnético variable.
    \part[3] Determine el flujo total del vector de Poynting a través de la superficie lateral del solenoide.
  \end{parts}

  \begin{solution}
    \begin{parts}
      \part Calculamos el flujo magnético por definición:
      \begin{equation}
        \Phi_B = \iint \bvec{B} \cdot \dif{\mathbf{a}} = \bvec{B} \, A.
      \end{equation}
      Donde $A = \pi \left(\frac{a}{2}\right)^2$ es el área de la espira. Por lo tanto:
      \begin{equation}
        \tcbhighmath{\Phi_B = \frac{\pi a^2}{4}B_0\cos(\omega t)}
      \end{equation}
      \part Gracias al hint, sabemos que:
      \begin{equation}
        \text{emf} = \oint \bvec{E} \cdot \dif{\mathbf{l}}.
      \end{equation}
      Y por Faraday-Lenz se tiene la siguiente relación:
      \begin{equation}
        \oint\bvec{E}\cdot\dif\mathbf{l} = -\frac{\dif}{\dif t}\iint\bvec{B}\cdot\dif\mathbf{a} \quad \Rightarrow \quad \text{emf} = -\frac{\dif}{\dif t}\Phi_B.
      \end{equation}
      Utilizando lo encontrado en el inciso anterior:
      \begin{equation}
        \text{emf} = \frac{\pi a^2}{4} B_0 \omega \sin(\omega t).
      \end{equation}
      Dividiendo por la resistencia $R$:
      \begin{equation}
        \Rightarrow \tcbhighmath{I(t) = \frac{\pi a^2}{4R} B_0 \omega \sin(\omega t)}
      \end{equation}

      \part Replicamos el procedimiento anterior para un camino circular de radio $r<a$ arbitrario
      \begin{equation}
        \Phi_{B,s} = \pi r^2 B_0 \cos(\omega t) \, \Rightarrow \, -\frac{\dif}{\dif t}\Phi_{B,s} = \pi r^2 \omega B_0 \sin(\omega t).
      \end{equation}
      Nuevamente por Faraday-Lenz en forma integral:
      \begin{align}
        \oint\bvec{E}\cdot\dif\mathbf{l} = \mathcal{E}(r) \cdot 2\pi r \\
        \bvec{E}(r) \cdot 2\pi r = \pi r^2 \omega B_0 \sin(\omega t)\, \uvecs{\phi}.
      \end{align}
      Despejando e incorporando la dirección del campo:
      \begin{equation}
        \tcbhighmath{
          \bvec{E}(r) = \frac{r \omega}{2} B_0 \sin(\omega t)\, \uvecs{\phi}
        }
      \end{equation}

      \part Partimos calculando el vector de Poynting dentro del solenoide:
      \begin{align}
        \bvec{S} & = \frac{1}{\mu_0}\del{\bvec{E}\times\bvec{B}}                                                                   \\
        \bvec{S} & = \frac{1}{\mu_0} \, \frac{r \omega}{2} B_0 \sin(\omega t)\, \uvecs{\phi} \times B_0 \cos(\omega t) \, \uvec{z} \\
        \bvec{S} & = \frac{\omega r}{2\mu_0} B_0^2 \cos(\omega t)\sin(\omega t) \, \uvec{r}
      \end{align}
      Luego, la energía por unidad de tiempo que atraviesa la superficie lateral (cilindro de radio $a$ y largo $l$) será:
      \begin{equation}
        \iint \bvec{S} \cdot \dif{\mathbf{a}} = \iint \frac{\omega a}{2\mu_0} B_0^2 \cos(\omega t)\sin(\omega t) \, a\dif{\phi}\dif{z}.
      \end{equation}
      \begin{equation}
        \tcbhighmath{
          \iint \bvec{S} \cdot \dif{\mathbf{a}} = \frac{\pi a^2}{\mu_0} \omega l B_0^2 \cos(\omega t)\sin(\omega t)
        }
      \end{equation}
    \end{parts}
  \end{solution}

  \question\label{q:crt} {Tubo de rayos catódicos y carga espacial}.
