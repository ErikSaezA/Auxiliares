  Considerando la masa y la carga del electrón como $m$ y $-e$, respectivamente, con $e>0$, responda secuencial-mente al siguiente set de preguntas.

  \begin{parts}
    \part[3] A partir del primer supuesto de la lista dada y de la relación $\mathcal{J} = -\uprho(x)\,v(x)$, exprese la densidad de carga $\uprho(x)$ como función del potencial $V(x)$ y de la densidad de corriente $\mathcal{J}$. \textit{Hint:} Puede usar la conservación de la energía,
    \begin{equation}
      \frac{1}{2}m v^2(x) = U_\text{potencial}.
    \end{equation}

    \part[3] Usando la ecuación de Poisson y el resultado anterior, muestre que el potencial $V(x)$ satisface una ecuación diferencial de la forma
    \[
      \frac{d^2V}{dx^2} = k\,V^{-1/2},
    \]
    donde $k$ es una constante que debe escribir en función de $\mathcal{J}$, $m$, $e$ y $\epsilon_0$. Luego, desarrollando la EDO e imponiendo las condiciones de borde, determine la expresión de $V(x)$ en el intervalo $0<x<l$.

    \part[3] A partir de $V(x)$, calcule el campo eléctrico $E(x)$ entre las placas y la energía electrostática total $W_e$ almacenada en el volumen entre ellas.

    \part[1] Use el resultado de la parte (b) para escribir la corriente total $I=\mathcal{J}A$ en la forma
    \[
      I = \frac{4\epsilon_0}{9}\,\sqrt{\frac{2e}{m}}\;V_1^{3/2}\,\frac{A}{l^2}.
    \]
    Verifique que esta expresión es dimensionalmente consistente si se usan como magnitudes fundamentales $M, L, T, I$ y se consideran las dimensiones
    \[
      [V] = \frac{M L^2}{T^3 I},
      \qquad
      [\epsilon_0] = \frac{I^2 T^4}{M L^3}.
    \]
  \end{parts}

  \begin{solution}
    \begin{parts}
    \part Como los electrones parten del cátodo con velocidad nula y se aceleran sólo por el campo electrostático,
    \[
      \frac{1}{2}m v^2(x) = e\,V(x)
      \;\Rightarrow\;
      v(x) = \sqrt{\frac{2e}{m}\,V(x)}.
    \]
    La densidad de corriente estacionaria se escribe como
    \[
      \mathcal{J} = -\uprho(x)\,v(x),
    \]
    por lo que
    \[
      \uprho(x) = -\frac{\mathcal{J}}{v(x)}
      = -\mathcal{J}\,\sqrt{\frac{m}{2e}}\;V(x)^{-1/2}.
    \]
    Nótese que $\uprho<0$ si $\mathcal{J}>0$, como corresponde a electrones.

    \part La ecuación de Poisson en 1D es
    \[
      \frac{d^2V}{dx^2} = -\frac{\uprho(x)}{\epsilon_0}
      = \frac{\mathcal{J}}{\epsilon_0}\sqrt{\frac{m}{2e}}\;V^{-1/2}.
    \]
    Definiendo
    \[
      k \equiv \frac{\mathcal{J}}{\epsilon_0}\sqrt{\frac{m}{2e}},
    \]
    se obtiene
    \[
      \frac{d^2V}{dx^2} = k\,V^{-1/2}.
    \]
    Escribimos $V'=\dfrac{dV}{dx}$ y usamos
    \[
      \frac{d^2V}{dx^2} = \frac{dV'}{dx}
      = \frac{dV'}{dV}\,\frac{dV}{dx}
      = V'\,\frac{dV'}{dV}.
    \]
    Entonces,
    \[
      V'\,\frac{dV'}{dV} = k\,V^{-1/2}
      \;\Rightarrow\;
      V'\,dV' = k\,V^{-1/2}\,dV.
    \]
    Integramos:
    \[
      \int V'\,dV' = \int k\,V^{-1/2}\,dV
      \;\Rightarrow\;
      \frac{(V')^2}{2} = 2k\,V^{1/2} + C.
    \]
    En $x=0$ se tiene $V(0)=0$ y el campo debe ser finito, lo que conduce naturalmente a $C=0$. De este modo,
    \[
      (V')^2 = 4k\,V^{1/2}
      \;\Rightarrow\;
      \frac{dV}{dx} = 2\sqrt{k}\,V^{1/4},
    \]
    donde tomamos la raíz positiva porque $V$ aumenta con $x$. Separando variables,
    \[
      \frac{dV}{V^{1/4}} = 2\sqrt{k}\,dx.
    \]
    Integramos entre $x=0$ y un $x$ genérico:
    \[
      \int_0^{V(x)} V^{-1/4}dV = 2\sqrt{k}\int_0^{x} dx
      \;\Rightarrow\;
      \frac{4}{3}V(x)^{3/4} = 2\sqrt{k}\,x.
    \]
    Es decir,
    \[
      V(x)^{3/4} = \frac{3}{2}\sqrt{k}\,x.
    \]
    Aplicando ahora la condición de borde $V(l)=V_1$:
    \[
      V_1^{3/4} = \frac{3}{2}\sqrt{k}\,l
      \;\Rightarrow\;
      \sqrt{k} = \frac{2}{3}\,\frac{V_1^{3/4}}{l}.
    \]
    Sustituyendo en la expresión general,
    \[
      V(x)^{3/4} = \frac{3}{2}\frac{2}{3}\,\frac{V_1^{3/4}}{l}\Bigr) x
      = V_1^{3/4}\,\frac{x}{l},
    \]
    lo que finalmente da
    \[
      V(x) = V_1\left(\frac{x}{l}\right)^{4/3},\qquad 0<x<l.
    \]

    \part El campo eléctrico es
    \[
      E(x) = -\frac{dV}{dx}
      = -\frac{d}{dx}\Bigl[V_1\Bigl(\frac{x}{l}\Bigr)^{4/3}\Bigr]
      = -\frac{4}{3}\frac{V_1}{l}\left(\frac{x}{l}\right)^{1/3}.
    \]
    Su magnitud es
    \[
      |E(x)| = \frac{4}{3}\frac{V_1}{l}\left(\frac{x}{l}\right)^{1/3}.
    \]
    La densidad de energía eléctrica es
    \[
      w_e(x) = \frac{1}{2}\epsilon_0 E^2(x),
    \]
    y la energía total entre las placas resulta
    \[
      W_e = \int_0^l \frac{1}{2}\epsilon_0 E^2(x)\,A\,dx
      = \frac{1}{2}\epsilon_0 A\int_0^l
      \left(\frac{4}{3}\frac{V_1}{l}\right)^2
      \left(\frac{x}{l}\right)^{2/3}dx.
    \]
    Sacando constantes e introduciendo $y=x/l$:
    \[
      W_e = \frac{1}{2}\epsilon_0 A\left(\frac{16}{9}\frac{V_1^2}{l^2}\right)
      \,l\int_0^1 y^{2/3}dy
      = \eval{\frac{8}{9}\epsilon_0 A\frac{V_1^2}{l}\,
      \frac{y^{5/3}}{5/3}}_0^1.
    \]
    Como $\int_0^1y^{2/3}dy = \frac{3}{5}$, se obtiene
    \[
      W_e = \frac{8}{15}\,\epsilon_0\,A\,\frac{V_1^2}{l}.
    \]

    \part De la definición de $k$ y del resultado de la parte (b),
    \[
      k = \frac{\mathcal{J}}{\epsilon_0}\sqrt{\frac{m}{2e}}
      = \frac{4}{9}\frac{V_1^{3/2}}{l^2},
    \]
    por lo que
    \[
      \mathcal{J} = \frac{4}{9}\,\epsilon_0\sqrt{\frac{2e}{m}}\,
      \frac{V_1^{3/2}}{l^2}.
    \]
    La corriente total es $I = \mathcal{J}A$, luego
    \[
      I = \frac{4\epsilon_0}{9}\sqrt{\frac{2e}{m}}\,
      V_1^{3/2}\,\frac{A}{l^2},
    \]
    como se quería demostrar.

    Para el análisis dimensional, usamos como magnitudes fundamentales $M,L,T,I$ y las dimensiones dadas:
    \[
      [V] = \frac{ML^2}{T^3 I},\qquad
      [\epsilon_0] = \frac{I^2 T^4}{ML^3},\qquad
      [e] = IT,\qquad
      [m]=M,\qquad
      [A]=L^2,\qquad
      [l]=L.
    \]
    El factor
    \[
      \epsilon_0\sqrt{\frac{2e}{m}}V_1^{3/2}\frac{A}{l^2}
    \]
    tiene dimensión
    \[
      [\epsilon_0]\,[e/m]^{1/2}\,[V]^{3/2}\,[A]\,[l]^{-2}
      = \del{\frac{I^2 T^4}{ML^3}}
      \del{\frac{IT}{M}}^{1/2}
      \del{\frac{ML^2}{T^3 I}}^{3/2}
      \frac{L^2}{L^2},
    \]
    lo que, simplificando, conduce a
    \[
      [I] = I,
    \]
    es decir, la expresión para $I$ es dimensionalmente consistente.
    \end{parts}
  \end{solution}

