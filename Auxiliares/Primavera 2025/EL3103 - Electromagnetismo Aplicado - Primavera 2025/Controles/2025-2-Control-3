      arc (-80:-20:1.25*\R);   % va creciendo el ángulo → antihorario
      \node[fill=white] at (-50:1.25*\R) {${\omega_0\uvec{z}}$};

      % Condiciones de borde
      \node at (4.15, 0) {${V_{m1}} = I_\text{enc}$};
