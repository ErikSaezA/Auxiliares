      \path[->] ({0.8*cos(40)},{0.8*sin(40)}) arc (40:80:0.8) coordinate (C);
      \pic [draw, ->, "\contour{white}{$\theta_2$}", angle eccentricity=.7, angle radius=1cm] {angle = B--O--C};
      \pic [draw, ->, "\contour{white}{$\theta_1$}", angle eccentricity=.7, angle radius=1cm] {angle = A--O--B};

