  \begin{parts}

    \part[6] {Planteamiento de campos y sistema}. Proponga para cada región una superposición de ondas progresivas y regresivas en $x$. Utilizando la continuidad de $E_t$ y $H_t$ en cada interfaz, determine el {sistema de ecuaciones} para las amplitudes de las ondas. Use las condiciones PEC en $E(0)=0$ y $E(L)=0$ para cerrar un sistema con cuatro amplitudes desconocidas. Justifique por qué en el tercer medio {sí} hay onda reflejada (efecto de la PEC en $x=L$).

    \bonuspart[3] {Subcascada aire 3 + PEC y reflexión efectiva en $x=L_1+d$}

    \begin{subparts}
      \subpart Trabaje en el tramo aire 3 con PEC en $x=L$ y demuestre que
      \begin{equation}\label{eq:Gamma3PEC}
        \widehat{R}_{(3|\text{PEC})}=-\,\euler^{-\ju \,2\beta_0 L_3}.
      \end{equation}

      \subpart Usando sólo continuidad de $E,H$ y el esquema de reflexiones múltiples (serie geométrica) en la cara $x=L_1+d$, obtenga la reflexión efectiva “vuelta al alimento”:
      \begin{equation}\label{eq:Gammab}
        \widehat{R}_b=r_{23}+\frac{t_{23}\,t_{32}\,\widehat{R}_{(3|\text{PEC})}}{1-r_{32}\,\widehat{R}_{(3|\text{PEC})}}.
      \end{equation}
    \end{subparts}

    \bonuspart[3] Reflexión total en $x=L_1$ y fórmula clave.
    \begin{subparts}
      \subpart Propague desde $x=L_1+d$ hasta $x=L_1$ a través del alimento y defina
      \begin{equation}\label{eq:qdef}
        q=\widehat{R}_b\,\euler^{-2j\widetilde{\beta_2} d}.
      \end{equation}

      \subpart En el plano $x=L_1$, con $r\equiv\widehat{R}_{\rm tot}$ definido como \textbf{onda hacia $-x$}/\textbf{onda hacia $+x$} en aire 1, y usando $G=qF$ en el alimento más continuidad de $E,H$, demuestre
      \begin{equation}\label{eq:key}
        \frac{1+r}{1-r}=\frac{\eta_0}{\eta_2}\,\frac{1+q}{1-q},\qquad \eta_2=\sqrt{\frac{\mu_0}{\epsilon_2}},
      \end{equation}
      y despeje $r$ explícitamente:
      \begin{equation}\label{eq:rfinal}
        r=\frac{\dfrac{\eta_0}{\eta_2}(1+q)-(1-q)}{\dfrac{\eta_0}{\eta_2}(1+q)+(1-q)}.
      \end{equation}
      {Reporte el \underline{porcentaje} de potencia reflejada y de potencia absorbida.}
    \end{subparts}

  \end{parts}

  \begin{solution}
    {Convención y notación.} Fasores con tiempo $\euler^{\ju\omega t}$. En aire:
    $\beta_0=\omega\sqrt{\mu_0\epsilon_0}$, $\eta_0=\sqrt{\mu_0/\epsilon_0}$.
    En el alimento (no magnético): $\epsilon_2=\epsilon_0(\epsilon_r'-j\epsilon_r'')$,
    $\eta_2=\sqrt{\mu_0/\epsilon_2}$, $\widetilde{\beta_2}=\beta_0\sqrt{\epsilon_r'-j\epsilon_r''}=\beta-j\alpha$.
      {Físicamente:} $\beta$ fija la fase, $\alpha>0$ modela {pérdidas} (calor).

    \begin{parts}
      \part Planteamiento de campos y sistema (paso a paso).
      \begin{enumerate}
        \item {Soluciones 1D por región (ondas viajeras):}
        \begin{align}
          E_1(x)      & =A\,\euler^{-\ju \beta_0 x}+B\,\euler^{+j\beta_0 x},                                                                                        &
          H_1(x)      & =\frac{1}{\eta_0}\!\left(A\,\euler^{-\ju \beta_0 x}-B\,\euler^{+j\beta_0 x}\right), \tag{S1}\label{eq:S1}                                     \\
          E_2(\Delta) & =F\,\euler^{-\ju \widetilde{\beta_2} \Delta}+G\,\euler^{+j\widetilde{\beta_2} \Delta},                                                      &
          H_2(\Delta) & =\frac{1}{\eta_2}\!\left(F\,\euler^{-\ju \widetilde{\beta_2} \Delta}-G\,\euler^{+j\widetilde{\beta_2} \Delta}\right), \tag{S2}\label{eq:S2}   \\
          E_3(y)      & =C\,\euler^{-\ju \beta_0 y}+D\,\euler^{+j\beta_0 y},                                                                                        &
          H_3(y)      & =\frac{1}{\eta_0}\!\left(C\,\euler^{-\ju \beta_0 y}-D\,\euler^{+j\beta_0 y}\right), \tag{S3}\label{eq:S3}
        \end{align}
        donde $\Delta=x-L_1$ y $y=x-(L_1+d)$. {Físicamente:} cada medio uniforme admite {superposición} de ondas hacia $\pm x$. En el alimento, $\widetilde{\beta_2}$ complejo introduce {atenuación} (absorción).

        \item {Fronteras PEC ($E_t=0$):}
        \begin{align}
          E_1(0)=0   & \Rightarrow A+B=0 \Rightarrow B=-A, \tag{S4}\label{eq:S4}                                                                        \\
          E_3(L_3)=0 & \Rightarrow C \euler^{-\ju \beta_0L_3}+D \euler^{+j\beta_0L_3}=0 \Rightarrow D=-C\,\euler^{-2j\beta_0L_3}. \tag{S5}\label{eq:S5}
        \end{align}
        {Físicamente:} la PEC {invierte} el campo (fase $\pi$). Obliga a una onda regresiva en aire 3.

        \item {Continuidad en $x=L_1$ (aire1 $\leftrightarrow$ alimento):} usando \eqref{eq:S4},
        \begin{align}
          E_1(L_1)=E_2(0) & :\quad A\!\left(\euler^{-\ju \beta_0L_1}-\euler^{+j\beta_0L_1}\right)=F+G, \tag{S6}\label{eq:S6}                                  \\
          H_1(L_1)=H_2(0) & :\quad \frac{A}{\eta_0}\!\left(\euler^{-\ju \beta_0L_1}+\euler^{+j\beta_0L_1}\right)=\frac{1}{\eta_2}(F-G). \tag{S7}\label{eq:S7}
        \end{align}

        \item {Continuidad en $x=L_1+d$ (alimento $\leftrightarrow$ aire3):} usando \eqref{eq:S5},
        \begin{align}
          F \euler^{-\ju \widetilde{\beta_2} d}+G \euler^{+j\widetilde{\beta_2} d}                & =C - C \euler^{-2j\beta_0 L_3}, \tag{S8}\label{eq:S8}                \\
          \frac{F \euler^{-\ju \widetilde{\beta_2} d}-G \euler^{+j\widetilde{\beta_2} d}}{\eta_2} & =\frac{C + C \euler^{-2j\beta_0 L_3}}{\eta_0}. \tag{S9}\label{eq:S9}
        \end{align}
      \end{enumerate}
      Las \cref{eq:S6,eq:S9}, con \cref{eq:S4,eq:S5}, cierran el sistema en $A,F,G,C$.

      \part Subcascada aire 3 + PEC y reflexión efectiva en $x=L_1+d$.
      \begin{enumerate}
        \item {Reflexión equivalente del tramo aire3+PEC:}
        \begin{equation}
          \boxed{\,\widehat{R}_{(3|\mathrm{PEC})}=-\,\euler^{-\ju 2\beta_0L_3}\,}. \tag{S10}\label{eq:S10}
        \end{equation}
        {Física:} inversión por PEC ($-$) y {fase ida-vuelta} $\euler^{-\ju 2\beta_0L_3}$.

        \item {Fresnel normal (para campos $E$):}
        \begin{equation}
          r_{ij}=\frac{\eta_j-\eta_i}{\eta_i+\eta_j},\qquad
          t_{ij}=\frac{2\,\eta_j}{\eta_i+\eta_j}. \tag{S11}\label{eq:S11}
        \end{equation}
        {Física:} $r_{ij}$ mide \textit{mismatch} de impedancias; $t_{ij}$ la fracción transmitida hacia $j$.

        \item {Reflexión efectiva vuelta al alimento (múltiples recorridos, derivación).}

        {Plano y normalización.}
        Evaluamos en $x=L_1+d^{-}$ (lado del alimento). Incidente (desde 2) normalizada a $1$.

        \medskip
        {Descomposición camino-a-camino.}
        \begin{subparts}
          \subpart \underline{Reflexión directa (sin entrar a 3):}
          \begin{equation}
            E^{(-)}_{2,\mathrm{dir}}=r_{23}. \tag{S12a}\label{eq:S12a}
          \end{equation}

          \subpart \underline{Una vuelta completa 3\,$\leftrightarrow$\,PEC:}
          \begin{equation}
            E^{(-)}_{2,\mathrm{1v}}=t_{23}\,\widehat{R}_{(3|\mathrm{PEC})}\,t_{32}. \tag{S12b}\label{eq:S12b}
          \end{equation}

          \subpart \underline{Con una reverberación extra en 3:}
          \begin{equation}
            E^{(-)}_{2,\mathrm{2v}}=t_{23}\,\widehat{R}_{(3|\mathrm{PEC})}\, \big(r_{32}\,\widehat{R}_{(3|\mathrm{PEC})}\big)\,t_{32}. \tag{S12c}\label{eq:S12c}
          \end{equation}

          \subpart \underline{General, $m$ reverberaciones:}
          \begin{equation}
            E^{(-)}_{2,\mathrm{m v}}=t_{23}\,\widehat{R}_{(3|\mathrm{PEC})}\,\big(r_{32}\,\widehat{R}_{(3|\mathrm{PEC})}\big)^{m-1}\,t_{32},\quad m=1,2,\dots \tag{S12d}\label{eq:S12d}
          \end{equation}
        \end{subparts}

        {Suma (serie geométrica).}
        \begin{align}
          \widehat{R}_b
           & = r_{23}\;+\; \sum_{m=1}^{\infty} E^{(-)}_{2,\mathrm{m v}}
          = r_{23}\;+\; t_{23}\,\widehat{R}_{(3|\mathrm{PEC})}\,t_{32}\sum_{m=0}^{\infty}\big(r_{32}\widehat{R}_{(3|\mathrm{PEC})}\big)^m \nonumber       \\[4pt]
           & =\boxed{\,r_{23}+\frac{t_{23}\,t_{32}\,\widehat{R}_{(3|\mathrm{PEC})}}{1-r_{32}\,\widehat{R}_{(3|\mathrm{PEC})}}\,}. \tag{S12}\label{eq:S12}
        \end{align}
        {Convergencia:} $|r_{32}\widehat{R}_{(3|\mathrm{PEC})}|<1$ (si $\to1$, alta $Q$ y grandes campos internos).

        \medskip
        {Observaciones.}
        \begin{itemize}
          \item $r_{23}$: reflexión al incidir desde $2$; $r_{32}$: desde $3$ (en normal, $r_{32}=-r_{23}$).
          \item Todos los factores se evalúan en el {mismo plano} $x=L_1+d$; $\widehat{R}_{(3|\mathrm{PEC})}$ ya incluye la fase ida-vuelta en 3.
          \item Sumamos {amplitudes} de $E$; para potencias se usa $|\cdot|^2$ y, si cambia el lado, la relación de impedancias.
        \end{itemize}
      \end{enumerate} % <-- cierra (b)

      \part {Reflexión total en $x=L_1$ y fórmula clave.}
      \begin{enumerate}
        \item {Propagación de vuelta por el alimento (ida+vuelta):}
        \begin{equation}
          \boxed{\,q=\widehat{R}_b\,\euler^{-2j\widetilde{\beta_2} d}\,},\qquad \widetilde{\beta_2}=\beta-j\alpha. \tag{S13}\label{eq:S13}
        \end{equation}
        {Física:} $\euler^{-2j\widetilde{\beta_2} d}=\euler^{-\ju 2\beta d}\,\euler^{-2\alpha d}$; la parte $\euler^{-2\alpha d}$ {reduce} amplitud (absorción).

        \item {Definiciones locales en $x=L_1$:}
        \begin{equation}
          A_1= A\,\euler^{-\ju \beta_0L_1},\quad B_1= B\,\euler^{+j\beta_0L_1},\quad
          \boxed{\,r\equiv\widehat{R}_{\mathrm{tot}}=\frac{B_1}{A_1}\,}. \tag{S14}\label{eq:S14}
        \end{equation}
        Entonces
        \begin{equation}
          E_1=A_1(1+r),\qquad H_1=\frac{A_1}{\eta_0}(1-r);\quad
          E_2=F(1+q),\quad H_2=\frac{F}{\eta_2}(1-q). \tag{S15}\label{eq:S15}
        \end{equation}

        \item {Continuidad en $x=L_1$ y relación clave:}
        \begin{align}
          A_1(1+r)                & =F(1+q), \tag{S16}\label{eq:S16}                \\
          \frac{A_1}{\eta_0}(1-r) & =\frac{F}{\eta_2}(1-q). \tag{S17}\label{eq:S17}
        \end{align}
        Eliminando $A_1,F$:
        \begin{equation}
          \boxed{\,\frac{1+r}{1-r}=\frac{\eta_0}{\eta_2}\,\frac{1+q}{1-q}\,}. \tag{S18}\label{eq:S18}
        \end{equation}
        Despejando $r$:
        \begin{equation}
          \boxed{\,r=\frac{\dfrac{\eta_0}{\eta_2}(1+q)-(1-q)}{\dfrac{\eta_0}{\eta_2}(1+q)+(1-q)}\,}. \tag{S19}\label{eq:S19}
        \end{equation}

        \item {Evaluación numérica (datos del enunciado):} $f=\qty{2.45}{\giga\hertz}$, $d=\qty{3}{\centi\m}$, $L_3=\qty{4}{\centi\m}$,
        $\epsilon_r'=55$, $\epsilon_r''=18$ $\Rightarrow |r|^2\simeq 0.587$:
        \begin{equation}
          \boxed{~\%\,\mathrm{reflejada}\approx 58.7\%,\qquad \%\,\mathrm{absorbida}\approx 41.3\%~}. \tag{S20}\label{eq:S20}
        \end{equation}
      \end{enumerate}

    \end{parts}

  \end{solution}

