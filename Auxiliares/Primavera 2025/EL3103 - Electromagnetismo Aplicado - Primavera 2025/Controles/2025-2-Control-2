  \begin{solution}
    \begin{parts}
      \part Para calcular $\widehat{R}$: Se obtiene la impedancia de carga normalizada $z_L = Z_\mathcal{L} / Z_0 = \frac{\complexnum{35 + 20j}}{100} = \complexnum{0.35 + 0.2j}$. Con esto:
      \begin{align}
        \widehat{R} & = \frac{Z_\mathcal{L}-Z_0}{Z_\mathcal{L}+Z_0} = \frac{z_L-1}{z_L+1} = \frac{\complexnum{-0.65 + 0.2 j}}{\complexnum{1.35 + 0.2j}} \\
        \widehat{R} & \approx \complexnum{-0.45 + 0.215 j}
      \end{align}
      Con esto, se obtiene el módulo $\mathbf{\enVert{\widehat{R}}}$:
      \begin{align}
        \mathbf{\enVert{\widehat{R}}} & = \sqrt{(-0.45)^2 + (0.215)^2} = 0.498
      \end{align}
      Y para calcular {VSWR}:
      \begin{align}
        \text{VSWR} = \frac{1+\enVert{\widehat{R}}}{1-\enVert{\widehat{R}}} = \frac{1+0.498}{1-0.498} \approx 2.98
      \end{align}

      \part Usando la fórmula:
      \begin{align}
        Z_\text{in} & = Z_0 \sbr{\frac{Z_\mathcal{L} + \ju Z_0 \tan{(\beta l)}}{Z_0 + \ju Z_\mathcal{L} \tan{(\beta l)}}}
      \end{align}
      Y reemplazando $l = \lambda / 4$ y $\beta = 2 \pi / \lambda$ se obtiene que:
      \begin{align}
        Z_\text{in} & = Z_0 \sbr{\frac{Z_\mathcal{L} + \ju Z_0 \tan{(\frac{2 \pi}{\lambda} \frac{\lambda}{4})}}{Z_0 + \ju Z_\mathcal{L} \tan{(\frac{2 \pi}{\lambda} \frac{\lambda}{4})}}} \\
        Z_\text{in} & = Z_0 \sbr{\frac{Z_\mathcal{L} + \ju Z_0 \tan{(\frac{\pi}{2})}}{Z_0 + \ju Z_\mathcal{L} \tan{(\frac{\pi}{2})}}}
      \end{align}
      Como $\tan{(\pi / 2)} \rightarrow \infty$ se tiene:
      \begin{align}
        Z_\text{in} & = Z_0 \sbr{\frac{Z_\mathcal{L} + \ju Z_0 \tan{(\frac{\pi}{2})}}{Z_0 + \ju Z_\mathcal{L} \tan{(\frac{\pi}{2})}}}                                \\
        Z_\text{in} & = Z_0 \sbr{\frac{Z_\mathcal{L} + \ju Z_0 \infty}{Z_0 + \ju Z_\mathcal{L} \infty}}                                                              \\
        Z_\text{in} & = Z_0 \frac{\infty}{\infty}\sbr{\frac{Z_\mathcal{L}/\infty + \frac{j Z_0 \infty}{\infty}}{Z_0/\infty + \frac{j Z_\mathcal{L} \infty}{\infty}}} \\
        Z_\text{in} & = Z_0\sbr{\frac{0 + \ju Z_0}{0 + \ju Z_\mathcal{L}}}                                                                                           \\
        Z_\text{in} & = \frac{Z_0^2}{Z_\mathcal{L}}
      \end{align}
      Y se obtiene lo pedido.

      Ahora, para realizar la adaptación, es importante darse cuenta que como queremos la impedancia del adaptador, $Z_\text{in} = Z_0$ y $Z_0 = Z_1$. Usando la fórmula anterior, despejamos $Z_1$:
      \begin{align}
        Z_0 & = \frac{Z_1}{Z_\mathcal{L}}                           \\
        Z_1 & = \sqrt{Z_0 \times Z_\mathcal{L}}                     \\
        Z_1 & = \sqrt{100 \times 55} = 74.162 \mathbf{\unit{ \ohm}}
      \end{align}
      Se espera obtener que $\widehat{R} = 0$ y que $\text{VSWR} = 1$, ya que si el proceso de adaptación está bien realizado se espera eliminar todas las reflexiones ($\widehat{R} = 0$). Por otro lado, recordemos que $\text{VSWR}$ indica qué tan bien adaptada se encuentra la línea y este índice va desde 1 hasta $\infty$. Por ende, si la línea está bien adaptada, se espera el mínimo posible ($\text{VSWR} = 1$).
    \end{parts}
  \end{solution}

  \question Considere una línea de transmisión con una impedancia característica $Z_0 = \qty{50}{\ohm}$ y una impedancia de carga $Z_\mathcal{L} = \complexqty{25 - 40j}{\ohm}$. Haciendo uso de la carta Smith, encuentre:

  \begin{parts}
    \part[2] El VSWR y el módulo del índice de reflexión $\enVert{\widehat{R}}$.
    \part[2] La impedancia de entrada vista a una distancia de $0.4 \lambda$.
    \part[2] ¿La línea se encuentra bien adaptada? ¿Qué interpretación le pueda dar a esta respuesta?
  \end{parts}

