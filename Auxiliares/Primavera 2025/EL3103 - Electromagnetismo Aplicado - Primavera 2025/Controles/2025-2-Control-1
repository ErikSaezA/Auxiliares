          \draw[dotted] (-\W,0) -- (-\W,-\H);
          \draw[dotted] (0,0) -- (0,-\H);
          \draw[dotted] (\W,0) -- (\W,-\H);
          \draw[dotted] (-\W,-\H) -- (\W,-\H);
          \draw[dotted] (-\H,0) -- (-\H,-\H);
          \draw[dotted] (\H,0) -- (\H,-\H);
          \draw[dotted] (-\W,\H) -- (\W,\H);
          \draw[dotted] (-\W,0) -- (-\W,\H);
          \draw[dotted] (\W,0) -- (\W,\H);
          \draw[dotted] (-\H,0) -- (-\H,\H);
          \draw[dotted] (0,0) -- (0,\H);
          \draw[dotted] (\H,0) -- (\H,\H);

          \node[circle, fill=red, text=white, inner sep=1pt] at (-\H,0) {$V_1$};
          \node[circle, fill=red, text=white, inner sep=1pt] at (0,0) {$V_2$};
          \node[circle, fill=red, text=white, inner sep=1pt] at (\H,0) {$V_3$};

          \draw[->|] (-\W,-\H) -- (-\H,-\H) node[midway, below] {$h=\qty{3}{\centi\m}$};
          \draw[->|] (-\W,-\H) -- (-\W,0) node[midway, left] {$h=\qty{3}{\centi\m}$};

          \node[above] at (0, \H) {$V=\qty{0}{\volt}$};
          \node[left] at (-\W,0) {$V=\qty{120}{\volt}$};
          \node[right] at (\W,0) {$V=\qty{80}{\volt}$};
          \node[below] at (0,-\H) {$V=\qty{0}{\volt}$};

          \node[] at (-{\W * .85}, {\H * .85}) {$\epsilon_1$};
          \node[white] at ({\W * .85}, {\H * .85}) {$\epsilon_2$};

        \end{tikzpicture}
        \captionof{figure}{Discretización de la placa con interfaz.}
      \end{center}

      Donde $h_x = h_y = \qty{3}{\centi\m}$. De esta forma, se obtiene el siguiente sistema de ecuaciones:
      \begin{align}
        V_1 & = \frac{1}{4}(120+0+0+V_2)                                                                  \\
        V_2 & = \frac{1}{2(\epsilon_1 + \epsilon_2)} \left[\epsilon_1 V_1 + 0+ 0 + \epsilon_2 V_3 \right] \\
        V_3 & = \frac{1}{4}(V_2 + 80 + 0 + 0).
      \end{align}
      Simplificado:
      \begin{align}
        V_1 & = \frac{1}{4}(120+V_2)                                                               \\
        V_2 & = \frac{1}{2(\epsilon_1 + \epsilon_2)} \left[\epsilon_1 V_1 + \epsilon_2 V_3 \right] \\
        V_3 & = \frac{1}{4}(V_2 + 80).
      \end{align}
      Y el sistema matricial queda:
      \begin{align}
        \begin{bmatrix}
          4           & -1                         & 0           \\
          -\epsilon_1 & 2(\epsilon_1 + \epsilon_2) & -\epsilon_2 \\
          0           & -1                         & 4
        \end{bmatrix}
        \begin{bmatrix}
          V_1 \\ V_2 \\ V_3
        \end{bmatrix}
         & =
        \begin{bmatrix}
          120 \\ 0 \\ 80
        \end{bmatrix}.
      \end{align}

      \part Reemplazando los valores de $\epsilon$ dados por el enunciado se obtiene:
      \begin{align}
        \begin{bmatrix}
          4             & -1            & 0            \\
          - 5\epsilon_0 & 14 \epsilon_0 & -2\epsilon_0 \\
          0             & -1            & 4
        \end{bmatrix}
        \begin{bmatrix}
          V_1 \\ V_2 \\ V_3
        \end{bmatrix}
         & =
        \begin{bmatrix}
          120 \\ 0 \\ 80
        \end{bmatrix}.
      \end{align}
      Y resolviendo el sistema se llega a los siguientes valores numéricos para los potenciales:
      \begin{align}
        V_1 \approx \qty{33.9}{\volt} \\
        V_2 \approx \qty{15.5}{\volt} \\
        V_3 \approx \qty{23.9}{\volt}
      \end{align}

      \part El campo se puede expresar como:
      \begin{align}
        \mathbf{E} & = - \nabla V = -\frac{\partial V}{\partial x} \hat{x} - \frac{\partial V}{\partial y}\, \uvec{y}.
      \end{align}
      Para calcular las derivadas en el punto central se utiliza central-difference:
      \begin{align}
        \frac{dV}{dx} & \approx \frac{V(x_2 + h) - V(x_2 - h)}{2h} = \frac{V_3 - V_1}{2 \cdot 3} = \frac{23.9 - 33.9}{6} \approx \qty{-1.7}{\volt\per\m} \\
        \frac{dV}{dy} & \approx \frac{V(y_2 + h) - V(y_2 - h)}{2h} = \frac{0 - 0}{2 \cdot 3} = \qty{0}{\volt\per\m}.
      \end{align}
      El campo obtenido es:
      \begin{align}
        \mathbf{E} & \approx \qty{1.7}{\volt\per\m}\, \uvec{x}.
      \end{align}
    \end{parts}
  \end{solution}

  \question \label{q:gm} {Contador Geiger} (\cref{fig:geiger}). Considere un tubo GM idealizado como un capacitor coaxial de longitud $L$, con ánodo (hilo) de radio $a$ y cátodo (cilindro) de radio interno $b$ ($a\ll b$), relleno con gas noble y mezcla de apagado a presión constante $P=\qty{1.013e5}{\pascal}$. El ánodo se polariza a un potencial {$V_0$} mediante una {resistencia de \textit{quenching}} $R$ en serie. La permitividad del gas puede tomarse como $\epsilon \simeq \epsilon_0$.

  Una partícula que atraviesa el gas deposita una energía {$U_{\rm dep}$} y crea pares ión--electrón.
  Como \textbf{primera aproximación} del efecto físico, supondremos que el desarrollo de la avalancha está gobernado exclusivamente por el \textbf{campo eléctrico local} $\mathbf{E}(r)$ dentro del gas, y que la microfísica de colisiones queda \textbf{encapsulada} en el coeficiente de \textit{Townsend} $\alpha(E)$, donde $E=\enVert{\mathbf{E}(r)}$ es la magnitud del campo.
  A presión fija, usaremos la ley de Townsend en función de $E$:
  \[
    \alpha(E)=A\,\exp\!\left(-\frac{B}{E}\right),
  \]
  con $A$ y $B$ constantes del gas. En este control, {solo será requerido calcular $\alpha$ a partir de $E(r)$} obtenido en la parte (a), y usarlo luego en las expresiones de ganancia.

