  \question Un tubo cilíndrico infinitamente largo, de radio $a$, se mueve a una velocidad constante $u$ a lo largo de su eje. Lleva una carga por unidad de largo $\uplambda$, distribuida uniformemente sobre su superficie. Rodeándolo, a un radio $b$, se encuentra otro cilindro que se mueve con la misma velocidad, pero que lleva una carga opuesta $-\uplambda$. Encuentre:
  \begin{parts}
    \part[2] El campo eléctrico en todo el espacio.
    \part[2] El campo magnético en todo el espacio.
    \part[3] La energía por unidad de largo almacenada en los campos.
    \part[3] La energía por unidad de tiempo transportada por los campos a través de un plano perpendicular a los cilindros.
  \end{parts}

  \begin{solution}
    \begin{parts}
      \part Para $r>b$ y $r<a$, el campo eléctrico será nulo.
      Para $a<r<b$, es posible aprovechar la simetría de la configuración para utilizar ley de Gauss. Sabemos que existe una carga $Q_{enc} = \uplambda\cdot l$. Así, el campo eléctrico estará dado por:
      \begin{align}
        \mathbf{E}(r) = \frac{\uplambda}{2\pi r \epsilon_0} \, \uvec{r}.
        \label{eq:campo electrico}
      \end{align}
      En resumen:
      \begin{equation}
        \mathbf{E} = \begin{cases}
          \mathbf{0} \quad r<a,                                         \\
          \frac{\uplambda}{2\pi r \epsilon_0} \, \uvec{r}, \quad a<r<b, \\
          \mathbf{0} \quad r>b.
        \end{cases}
      \end{equation}

      \part Para $r>b$ y $r<a$, el campo magnético será nulo. Dado que el cilindro interior se mueve a una velocidad $u$, se generará una corriente de conducción:
      \begin{align}
        I = \uplambda u.
      \end{align}
      Por regla de la mano derecha, el campo magnético en $a<r<b$ cumple:
      \begin{align}
        \mathbf{B} = B(r)\, \uvec{\phi}.
      \end{align}
      Ocupando la ley de Ampère-Maxwell, es posible encontrar el campo magnético:
      \begin{align}
        \mathbf{B}(r) = \mu_0 \frac{\uplambda u}{2\pi r}\uvec{\phi}.
      \end{align}
      En resumen:
      \begin{equation}
        \mathbf{B} = \begin{cases}
          \mathbf{0} \quad r<a,                                     \\
          \mu_0 \frac{\uplambda u}{2\pi r}\uvec{\phi}, \quad a<r<b, \\
          \mathbf{0} \quad r>b.
        \end{cases}
      \end{equation}

      \part Ocupamos la fórmula para la energía electromagnética:
      \begin{align}
        U_\text{em}                       & = \frac{1}{2}\int_{0}^{l}\int_{0}^{2\pi}\int_{a}^{b}\epsilon_0\del{\frac{\uplambda}{2\pi r \epsilon_0}}^2+\frac{1}{\mu_0}\del{\mu_0 \frac{\uplambda u}{2\pi r}}^2r\dif{r}\dif{\phi}\dif{z} \\
                                          & = \frac{\uplambda^2l}{4\pi\epsilon_0}\int_{a}^{b}\frac{1}{r}(1+\mu_0\epsilon_0u^2)\dif{r}                                                                                                  \\
        \Rightarrow \frac{U_\text{em}}{l} & = \frac{\uplambda^2}{4\pi\epsilon_0}\ln{\del{\frac{b}{a}}}(1+\mu_0\epsilon_0 u^2).
      \end{align}
      \part Calculamos el vector de Poynting:
      \begin{align}
        \mathbf{S} & = \frac{1}{\mu_0}(\mathbf{E}\times\mathbf{B}),       \\
        \mathbf{S} & = \frac{\uplambda^2u}{4\pi^2r^2\epsilon_0} \uvec{z}.
      \end{align}
      Luego, la energía por unidad de tiempo a través de un plano perpendicular a los cilindros será:
      \begin{align}
        \dod{U_\text{em}}{t} & = \int\int\mathbf{S}\cdot \dif{\mathbf{a}}= \frac{\uplambda^2u}{4\pi^2\epsilon_0}\cdot 2\pi \int_{a}^{b}\frac{1}{r}\dif{r}= \frac{\uplambda^2u}{2\pi\epsilon_0}\ln{\del{\frac{b}{a}}}.
      \end{align}
    \end{parts}
  \end{solution}

