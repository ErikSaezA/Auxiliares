  Datos dimensiones y cantidades físicas del sistema ilustrador en \cref{fig:geiger}.
  \begin{align*}
    a & =\qty{25}{\micro\m}, & b & =\qty{1}{\centi\m}, & L & =\qty{10}{\centi\m}, & V_0 & =\qty{900}{\volt},
    \\ W&=\qty{26}{\electronvolt}, & A&=\qty{3.04e5}{\per\m}, & B&=\qty{7.6e6}{\volt\per\m} & R&=\qty{10}{\mega\ohm}.
  \end{align*}
  Aquí $W$ es la energía media por par ión--electrón del gas.

  \begin{parts}
    \part {Electrostática del coaxial}.
    \begin{subparts}
      \subpart[4] Resuelva la ecuación de Laplace sobre la geometría del coaxial para el potencial eléctrico y, usando dicho potencial, demuestre que el campo eléctrico dentro del volumen del gas es
      \[
        \mathbf{E}(r)=\frac{V_0}{r\,\ln(b/a)}\,\uvec{r}.
      \]
      \subpart[2] Determine la {capacitancia por unidad de longitud} del coaxial y la {capacitancia total} $C$ del tubo.
    \end{subparts}

    \part {Avalancha y carga transferida}.
    \begin{subparts}
      \subpart[1] Estime el número de pares primarios generados considerando $U_{\rm dep}=\qty{1.2e6}{\electronvolt}$:
      \[
        N_0=\dfrac{U_{\rm dep}}{W}.
      \]
      \subpart[1] Suponiendo que un electrón “semilla” nace en $r_0\in(a,b)$ y deriva al ánodo, escriba la {ganancia} por avalancha
      \[
        M(r_0)=\exp\!\Bigg( \int_{r_0}^{a}\alpha\!\big(E(r)\big)\,\dif{r} \Bigg).
      \]
      \subpart[2] Considere que la semilla nace a mitad de camino entre $a$ y $b$, es decir $r_0=\dfrac{a+b}{2}$. Obtenga el {número total de electrones},
      \[
        N_e \approx N_0\,M(r_0),
      \]
      y determine la {carga transferida a los electrodos}.
    \end{subparts}

    \bonuspart {Circuito RC y pulso de tensión}.
    \begin{subparts}
      \bonussubpart[2] Resuelva la tensión del tubo en el tiempo considerando que antes de $t^\ast$ el circuito está en equilibrio.
      La avalancha en $t=t^\ast$ descarga instantáneamente el capacitor en una caída $\Delta V$ y luego el sistema se recupera con la constante de tiempo $\tau=RC$. Debe demostrar que el resultado es de la forma
      \[
        V_{\text{tubo}}(t)=V_0-\Delta V\,e^{-(t-t^\ast)/(RC)}\,u(t-t^\ast),
      \]
      donde $u(\cdot)$ es la función escalón de Heaviside (vale $0$ si su argumento es negativo y $1$ si es no negativo).

      \bonussubpart[2] Graficar $V_{\text{tubo}}(t)$ indicando numéricamente $\Delta V$ y $\tau$.
    \end{subparts}
  \end{parts}

  \begin{solution}
    \begin{parts}
      \part En coordenadas cilíndricas, con simetría en $\theta$ y $z$:
      \[
        \nabla^2 V=\frac{1}{r}\dod{}{r}\!\left(r\dod{V}{r}\right)=0\ \Rightarrow\
        V(r)=C_1\ln r + C_2.
      \]
      Con $V(a)=V_0$, $V(b)=0$ se obtiene
      \[
        V(r)=\frac{V_0}{\ln(b/a)}\ln\!\frac{b}{r},\qquad
        \mathbf{E}(r)=-\nabla V=\frac{V_0}{r\,\ln(b/a)}\,\hat{\mathbf r}.
      \]
      Ley de Gauss con $\mathbf D=\epsilon\mathbf E$ da
      \[
        C'=\frac{2\pi\epsilon}{\ln(b/a)},\qquad C=C' L=\frac{2\pi\epsilon L}{\ln(b/a)}.
      \]

      \part Con $U_{\rm dep}=\qty{1.2e6}{\electronvolt}$, $W=\qty{26}{\electronvolt}$:
      \[
        N_0=\frac{U_{\rm dep}}{W}\approx \num{4.6e4}.
      \]
      A presión fija $\alpha(E)=A \mathrm{e}^{-B/E}$ y $E(r)=V_0/[r\ln(b/a)]$ $\Rightarrow$
      \[
        \alpha(r)=A\exp\!\Big[-\tfrac{B\ln(b/a)}{V_0}\,r\Big]=A \mathrm{e}^{-k r},\quad k=\tfrac{B\ln(b/a)}{V_0}.
      \]
      Entonces
      \[
        M(r_0)=\exp\!\left(\int_{a}^{r_0}\alpha(r)\,dr\right)=
        \exp\!\left(\frac{A}{k}\,[\mathrm{e}^{-ka}-\mathrm{e}^{-k r_0}]\right).
      \]
      Con $r_0=\tfrac{a+b}{2}$:
      \[
        N_e\approx N_0\,M(r_0),\qquad Q=eN_e.
      \]

      \part En DC el capacitor es abierto $\Rightarrow$ no hay corriente y $V_{\text{tubo}}(t<t^\ast)=V_0$.
      La avalancha transfiere $Q$ y provoca $\Delta V=Q/C$ instantánea. Para $t>t^\ast$:
      \[
        \frac{dV_{\text{tubo}}}{dt}+\frac{1}{RC}V_{\text{tubo}}=\frac{V_0}{RC},\quad
        V_{\text{tubo}}(t^\ast{}^+)=V_0-\Delta V,
      \]
      de donde
      \[
        V_{\text{tubo}}(t)=V_0-\Delta V\,\mathrm{e}^{-(t-t^\ast)/(RC)}\,u(t-t^\ast).
      \]
      % Figura esquemática (escala arbitraria) del pulso V_tubo(t)
      \begin{center}
        \begin{tikzpicture}[line cap=round,line join=round]
          \def\xmax{8}\def\ymax{3.5}\def\Vzero{2.5}\def\dV{1.2}\def\tstar{2.0}
          \draw[-latex] (0,0) -- (\xmax+0.2,0) node[below] {$t$};
          \draw[-latex] (0,0) -- (0,\ymax) node[left] {$V_{\text{tubo}}$};
          \draw[dashed] (0,\Vzero) -- (\xmax,\Vzero); \node[above right] at (0.05,\Vzero) {$V_0$};
          \draw[very thick, blue] (0,\Vzero) -- (\tstar,\Vzero);
          \draw[very thick, blue] (\tstar,\Vzero) -- (\tstar,{\Vzero-\dV});
          \draw[very thick,blue,domain=\tstar:\xmax,samples=200] plot (\x, {\Vzero-\dV*exp(-(\x-\tstar)/1.3)});
          \draw[dotted] (\tstar,0) -- (\tstar,\ymax); \node[below] at (\tstar,0) {$t^\ast$};
          \draw[<->|] (\tstar-0.5,\Vzero) -- node[fill=white] {$\Delta V$} (\tstar-0.5,{\Vzero-\dV});
          \pgfmathsetmacro{\tone}{\tstar+1.3}
          \draw[dotted] (\tone,0) -- (\tone,\ymax); \node[below] at (\tone,0) {$t^\ast+\tau$};
          \fill (\tone, {\Vzero-\dV*exp(-1)}) circle (1.2pt);
        \end{tikzpicture}
        \captionof{figure}{Diagrama potencial $V_\text{tubo}\del{t}$.}
      \end{center}

    \end{parts}
  \end{solution}

